# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
# Exclude build artifacts in dist/ except committed release packages
dist/*
!dist/*.deb
!dist/*.apk
*.egg

# Virtual environments
.venv/
venv/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# CIEL/Ω runtime-generated reports and memory state
# (created by CielEngine during test runs / normal execution)
integration/Orbital/main/reports/global_orbital_coherence_pass/orbital_*/
integration/reports/pipeline_maintenance/*.json
integration/Orbital/main/data/source/CIEL_OMEGA_COMPLETE_SYSTEM/CIEL_MEMORY_SYSTEM/ORBITAL_MEMORY/sector_events.ndjson
integration/Orbital/main/data/source/CIEL_OMEGA_COMPLETE_SYSTEM/CIEL_MEMORY_SYSTEM/TSM/ledger/memory_ledger.db

# Vendor wheels — generated by packaging/vendor/download_wheels.sh (not committed)
packaging/vendor/*.whl
packaging/vendor/*.tar.gz
packaging/vendor/*.zip

# Generated card/catalog database library (rebuild from scripts, do not commit binaries)
integration/registries/definitions/db_library/*.sqlite
integration/registries/definitions/db_library/*-journal
integration/registries/definitions/db_library/*.sqlite-wal
integration/registries/definitions/db_library/*.sqlite-shm
