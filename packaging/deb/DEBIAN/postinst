#!/bin/sh
# Post-installation script for ciel-sot-agent
#
# Creates an isolated virtual environment at /opt/ciel-sot-agent/venv and
# installs the application from pre-bundled wheels — no internet access
# required.

set -e

INSTALL_DIR="/opt/ciel-sot-agent"
WHEELS_DIR="${INSTALL_DIR}/wheels"
VENV_DIR="${INSTALL_DIR}/venv"

echo "[ciel-sot-agent] Creating virtual environment at ${VENV_DIR}..."
python3 -m venv "${VENV_DIR}"

echo "[ciel-sot-agent] Installing from bundled wheels (offline)..."
"${VENV_DIR}/bin/pip" install \
    --quiet \
    --no-index \
    --find-links "${WHEELS_DIR}" \
    "ciel-sot-agent[gui]"

echo "[ciel-sot-agent] Creating /var/lib/ciel/models directory..."
mkdir -p /var/lib/ciel/models

echo "[ciel-sot-agent] Reloading systemd daemon..."
systemctl daemon-reload || true

echo "[ciel-sot-agent] Installation complete."
echo "  Start the GUI:    ciel-sot-gui"
echo "  Enable service:   sudo systemctl enable --now ciel-sot-gui"
echo "  List models:      ciel-sot-install-model --list"

